[Unit]
Description=Kronos Agent OS agent %i
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=kronos
WorkingDirectory=/opt/kaos/app
ExecStart=/opt/kaos/app/.venv/bin/python -m kronos
Restart=on-failure
RestartSec=10

EnvironmentFile=/opt/kaos/app/.env
Environment=DB_DIR=./data/%i
Environment=DB_PATH=./data/%i/session.db
Environment=SESSION_FILE=%i.session
Environment=WORKSPACE_PATH=./workspaces/%i
EnvironmentFile=-/opt/kaos/app/.env.%i
Environment=AGENT_NAME=%i

KillMode=control-group
KillSignal=SIGTERM
TimeoutStopSec=30

LimitNOFILE=65536
MemoryMax=2G

StandardOutput=journal
StandardError=journal
SyslogIdentifier=kaos-%i

[Install]
WantedBy=multi-user.target
