# ============================================================
# Nexus — Environment Variables
# Copy to .env.nexus and fill in real values
# ============================================================

# === Agent Identity ===
AGENT_NAME=nexus
SESSION_FILE=nexus.session

# === LLM Providers (same as main agent) ===
FIREWORKS_API_KEY=fw_...
DEEPSEEK_API_KEY=sk-...
OPENAI_API_KEY=sk-proj-...

# === Telegram Bridge ===
TG_API_ID=12345678                    # unique per agent (https://my.telegram.org)
TG_API_HASH=abc123...
TG_BOT_TOKEN=                         # empty = userbot mode
ALLOWED_USERS=                        # comma-separated Telegram user IDs
WEBHOOK_SECRET=nexus-change-me
WEBHOOK_PORT=8789                     # different port from main agent (8788)
DEFAULT_NOTIFY_CHAT=                  # Telegram chat ID for cron notifications

# === Voice STT (Groq Whisper) ===
GROQ_API_KEY=gsk_...

# === MCP Servers (same as main agent) ===
BRAVE_API_KEY=BSA...
EXA_API_KEY=
NOTION_API_KEY=ntn_...
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
COMPOSIO_API_KEY=

# === NTFY Push Notifications (optional) ===
NTFY_URL=https://ntfy.sh
NTFY_TOKEN=tk_...
NTFY_TOPIC=nexus-alerts               # separate topic from main agent

# === Memory (Mem0) ===
MEM0_QDRANT_PATH=./data/nexus-qdrant  # separate from main agent

# === Observability (optional) ===
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

# === Agent ===
# workspace_path left empty — resolved from AGENT_NAME → workspaces/nexus/
DB_PATH=./data/nexus.db
CONTEXT_STRATEGY=summarize
