# ============================================================
# Kronos Agent OS (KAOS) — Environment Variables
# Copy to .env and fill in real values
# ============================================================

# === LLM Providers ===
# Defaults preserve the original KAOS setup:
#   standard: Fireworks/Kimi -> DeepSeek
#   lite:     DeepSeek -> Fireworks/Kimi
KAOS_STANDARD_PROVIDER_CHAIN=kimi,deepseek
KAOS_LITE_PROVIDER_CHAIN=deepseek,kimi
# Optional: route only the top-level supervisor/orchestrator through Codex CLI
# OAuth credentials while leaving sub-agents and cron jobs on standard/lite chains.
# KAOS_ORCHESTRATOR_PROVIDER_CHAIN=codex-cli

FIREWORKS_API_KEY=                   # preset: kimi/fireworks, e.g. fw_...
DEEPSEEK_API_KEY=                    # preset: deepseek, e.g. sk-...
OPENAI_API_KEY=                      # preset: openai, e.g. sk-proj-...
KAOS_CODEX_COMMAND=codex             # preset: codex-cli, requires `codex login --device-auth`
KAOS_CODEX_MODEL=gpt-5.5
KAOS_CODEX_TIMEOUT_SECONDS=180

# Bring your own provider by changing the chain and provider settings.
# Built-in preset ids: kimi, fireworks, deepseek, openai, openrouter, groq,
# together, codex-cli, litellm, ollama, local.
#
# Example: OpenRouter
# KAOS_STANDARD_PROVIDER_CHAIN=openrouter,deepseek
# OPENROUTER_API_KEY=sk-or-...
# KAOS_PROVIDER_OPENROUTER_MODEL=openai/gpt-4.1-mini
#
# Example: local Ollama/OpenAI-compatible endpoint
# KAOS_LITE_PROVIDER_CHAIN=ollama
# KAOS_PROVIDER_OLLAMA_MODEL=llama3.1
# KAOS_PROVIDER_OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
#
# Example: arbitrary OpenAI-compatible provider
# KAOS_STANDARD_PROVIDER_CHAIN=my_lab
# KAOS_PROVIDER_MY_LAB_MODEL=my-model
# KAOS_PROVIDER_MY_LAB_BASE_URL=https://llm.example.com/v1
# KAOS_PROVIDER_MY_LAB_API_KEY_ENV=MY_LAB_API_KEY
# MY_LAB_API_KEY=sk-...

# === Telegram Bridge ===
TG_API_ID=12345678
TG_API_HASH=abc123...
TG_BOT_TOKEN=                         # Bot API token (optional, alternative to userbot)
ALLOWED_USERS=                        # comma-separated Telegram user IDs
ALLOW_ALL_USERS=false                 # set true only for trusted/private accounts
WEBHOOK_SECRET=change-me-secret
WEBHOOK_PORT=8788
DEFAULT_NOTIFY_CHAT=                  # Telegram chat ID for cron notifications
TELEGRAM_GROUP_RESPONSES_ENABLED=true # set false for observe-only Telegram sessions
TELEGRAM_SWARM_CHAT_ID=0              # supergroup id; accepts 364... or -100364...
TELEGRAM_GENERAL_TOPIC_ID=0           # smart multi-agent routing topic
TELEGRAM_KRONOS_TOPIC_ID=0            # dedicated Kronos II topic
TELEGRAM_FINANCE_TOPIC_ID=0           # dedicated finance topic
TELEGRAM_DIGEST_TOPIC_ID=0            # digest/report topic
TELEGRAM_KRONOS_AGENT=kronos
TELEGRAM_FINANCE_AGENT=kronos
TELEGRAM_DIGEST_AGENT=kronos
TELEGRAM_DIGEST_NEWS_AGENT=kronos
TELEGRAM_JB_COMPETITORS_AGENT=nexus
TELEGRAM_JB_SYSTEM_AGENT=nexus
TELEGRAM_DIGEST_JOBS_AGENT=kronos
TELEGRAM_DIGEST_IDEAS_AGENT=kronos
TELEGRAM_JB_TRAVEL_INSIGHTS_AGENT=kronos
TELEGRAM_SHARED_CONTEXT_MESSAGES=12

# === Dashboard ===
DASHBOARD_HOST=127.0.0.1              # localhost-only by default
DASHBOARD_PORT=8789
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=                   # if empty, generated at startup and logged locally

# === Voice STT (Groq Whisper) ===
GROQ_API_KEY=gsk_...

# === Discord (optional) ===
DISCORD_BOT_TOKEN=
DISCORD_ALLOWED_GUILDS=               # comma-separated guild IDs

# === MCP Servers ===
BRAVE_API_KEY=BSA...                  # Brave web search
EXA_API_KEY=                          # Exa semantic search
NOTION_API_KEY=ntn_...                # Notion workspace
GOOGLE_OAUTH_CLIENT_ID=               # Google Workspace (Gmail, Calendar)
GOOGLE_OAUTH_CLIENT_SECRET=
COMPOSIO_API_KEY=                     # Composio 250+ integrations (optional)

# === Capability Gates (public-safe defaults) ===
ENABLE_DYNAMIC_TOOLS=false            # opt-in: agent-created Python tools
REQUIRE_DYNAMIC_TOOL_SANDBOX=true     # fail closed unless Docker sandbox is available
ENABLE_MCP_GATEWAY_MANAGEMENT=false   # opt-in: add/remove/reload MCP servers at runtime
ENABLE_DYNAMIC_MCP_SERVERS=false      # opt-in: load MCP servers persisted in local registry
ENABLE_SERVER_OPS=false               # opt-in: SSH/server diagnostics and whitelisted actions

# === NTFY Push Notifications (optional) ===
NTFY_URL=https://ntfy.sh
NTFY_TOKEN=tk_...
NTFY_TOPIC=kronos-alerts

# === Memory (Mem0) ===
MEM0_QDRANT_PATH=./data/qdrant       # Qdrant local mode, no external service

# === Observability (optional) ===
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

# === Agent ===
AGENT_NAME=kronos                     # kronos | kaos-worker | kaos-analyst
# WORKSPACE_PATH=                     # override; if empty, resolved from AGENT_NAME
# SHARED_WORKSPACE_PATH=              # optional common workspace for shared skills
# DB_PATH=                            # override; if empty, resolved to ./data/<agent_name>/session.db
CONTEXT_STRATEGY=summarize            # summarize | sliding_window | hybrid

# === Multi-Agent Deployment ===
# Each agent runs as a separate process with its own:
#   - AGENT_NAME (selects workspace)
#   - TG_API_ID + TG_API_HASH (unique Telegram account)
#   - Session file: <agent_name>.session (created by scripts/auth-userbot.py)
#   - DB: ./data/<agent_name>.db (auto-resolved)
#   - WEBHOOK_PORT (unique per agent if using webhook)
#
# Deploy options:
#   1. Separate .env per agent: .env.kronos, .env.worker, etc.
#   2. Systemd: Environment= overrides in unit files
#   3. Docker: env_file per container

# === Cron: Bot API topics (optional) ===
TOPIC_GENERAL=0                       # Telegram topic ID for general notifications
TOPIC_DIGEST=0                        # Telegram topic ID for digests
TOPIC_FINANCE=0                       # Telegram topic ID for finance notifications
TOPIC_DIGEST_NEWS=0                   # AI/news/tools digest; falls back to TOPIC_DIGEST
TOPIC_JB_COMPETITORS=0                # JourneyBay competitor reports; falls back to TOPIC_DIGEST
TOPIC_JB_SYSTEM=0                     # JourneyBay system/product status; falls back to TOPIC_DIGEST
TOPIC_DIGEST_JOBS=0                   # Jobs digest; falls back to TOPIC_DIGEST
TOPIC_DIGEST_IDEAS=0                  # Product/business ideas digest; falls back to TOPIC_DIGEST
TOPIC_JB_TRAVEL_INSIGHTS=0            # JourneyBay travel insights; falls back to TOPIC_DIGEST

# === ASO Pipeline (optional) ===
ASC_KEY_ID=                           # App Store Connect
ASC_ISSUER_ID=
ASC_PRIVATE_KEY=
ASO_DB_PATH=./data/aso.db
